---
import Layout from "../layouts/Layout.astro";
import "../css/index.css";
---

<Layout>
  <section class="hero">
    <nav>
      <a href="/" class="logotype">La guanerita</a>

      <div class="sections">
        <a href="/">Acerca</a>
        <a href="/">Productos</a>
        <a href="/">Contacto</a>
      </div>
    </nav>
    <div class="content">
      <img src="./lupulo.png" alt="" class="lupulo lupulo_2" />
      <img src="./lupulo.png" alt="" class="lupulo lupulo_3" />
      <h1>Siente la Fuerza de Nuestra Tierra en cada Sorbo</h1>
      <a href="/" class="button">Probar ahora</a>
      <div class="bottle">
        <img src="./bottle.png" alt="La guanerita" />
      </div>
    </div>
  </section>

  <section class="about">
    <img src="./chicamocha (2).png" alt="" class="chicamocha" />
    <div class="content">
      <div class="info">
        <h2>La Pasión de Pienta A.Y.C.A.R</h2>
        <p>
          Detrás de cada gota de carácter dorado está la mano y la visión de
          nuestro Maestro Cervecero, Felipe Álvarez. En el corazón de Santander,
          seleccionamos los granos más puros y el lúpulo con más alma para crear
          una receta que no sigue modas, sino tradiciones. Somos una cervecería
          de autor donde la paciencia es nuestro ingrediente secreto
        </p>
      </div>

      <a href="/" class="button">Saber mas</a>

    </div>
  </section>
  <section class="products">
    <div class="bg">
      <h2>Nuestros productos</h2>

      <img src="./lupulo_hoja.png" alt="Lupulo" class="up" />
      <img src="./lupulo_hoja.png" alt="Lupulo" class="down" />
      <img src="./guanerita (2).png" alt="" class="guane" />

      <div class="beers" style={{ "--quantity": 8 }}>
        <img
          src="./etiquetas/cafe.png"
          alt=""
          class="item"
          style={{ "--position": 1 }}
        />
        <img
          src="./etiquetas/dorada.png"
          alt=""
          class="item"
          style={{ "--position": 2 }}
        />
        <img
          src="./etiquetas/menta_jengibre.png"
          alt=""
          class="item"
          style={{ "--position": 3 }}
        />
        <img
          src="./etiquetas/miel.png"
          alt=""
          class="item"
          style={{ "--position": 4 }}
        />
        <img
          src="./etiquetas/roja.png"
          alt=""
          class="item"
          style={{ "--position": 5 }}
        />
        <img
          src="./etiquetas/tequila.png"
          alt=""
          class="item"
          style={{ "--position": 6 }}
        />
        <img
          src="./etiquetas/negra.png"
          alt=""
          class="item"
          style={{ "--position": 7 }}
        />
        <img
          src="./etiquetas/wtyrriv.png"
          alt=""
          class="item"
          style={{ "--position": 8 }}
        />
      </div>
    </div>
  </section>

  <section class="soul">
    <div class="content">
      <h2>EL ESPÍRITU INDOMABLE DE SANTANDER</h2>
      <p>
        No somos solo una cerveza artesanal; somos la fuerza del Cañón del
        Chicamocha, la berraquera de nuestra gente y la tradición de una tierra
        que no se rinde. Guanerita Negra es la herencia líquida de Santander.
      </p>
    </div>

    <video src="./Woman.mp4" autoplay loop muted 
    playsinline
    poster="./poster.webp"></video>
  </section>

  <script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    // Registramos el plugin ScrollTrigger
    gsap.registerPlugin(ScrollTrigger);

    // --- ANIMACIÓN 1: La Botella Baja ---
    document.addEventListener("DOMContentLoaded", () => {
      const bottle = document.querySelector(".bottle");
      const aboutSection = document.querySelector(".about");
      const card = document.querySelectorAll(".card");
      const beer = document.querySelectorAll(".item");
      const guane = document.querySelector(".guane");
      const soulText = document.querySelectorAll(
        ".soul .content h2, .soul .content p",
      );
      const soulVideo = document.querySelector(".soul video");

      // Creamos la animación de la botella
      gsap.to(bottle, {
        y: "100vh", // Se mueve una altura de viewport hacia abajo
        rotation: -15, // Pequeña rotación para dinamismo

        // Configuración de ScrollTrigger
        scrollTrigger: {
          trigger: aboutSection, // Empieza cuando la sección about entra en vista
          start: "top bottom", // Empieza cuando el top de 'about' toca el bottom del viewport
          end: "top top", // Termina cuando el top de 'about' toca el top del viewport
          scrub: true, // Vincula la animación al scroll (suave)
        },
      });

      // --- ANIMACIÓN 2: Parallax de Productos + Desvanecimiento de Botella ---
      const productsSection = document.querySelector(".products");
      const soul = document.querySelector(".soul");

      gsap.to(productsSection, {
        y: "-300px",
        scrollTrigger: {
          trigger: productsSection,
          start: "top bottom",
          end: "top center", // Termina de subir antes para que el efecto sea claro
          scrub: 1.5,
          onUpdate: (self) => {
            // self.progress es un valor de 0 a 1 según el scroll
            // Hacemos que la opacidad sea la inversa del progreso
            gsap.set(bottle, { opacity: 0 - self.progress });
          },
        },
      });

      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: productsSection,
          start: "top bottom",
          end: "top center",
          scrub: 1.5,
        },
      });

      tl.to(productsSection, { y: "-300px" }, 2)
        .to(card, { opacity: 1, y: 0 }, 1.5)
        .to(guane, { opacity: 1, bottom: "-30%", immediateRender: false }, 2)
        .to(beer, { opacity: 1, y: 0 }, 2);

      const soulTl = gsap.timeline({
        scrollTrigger: {
          trigger: soul, // Se activa con la sección 'soul'
          start: "top bottom =800", // Empieza cuando la sección entra por abajo
          end: "top top", // Termina cuando la sección llena la pantalla
          scrub: 1.5,
        },
      });

      soulTl.to(soul, { y: "-300px" }, 0.1);

      soulTl.from(
        soulText,
        {
          y: 100, // Viene desde abajo
          opacity: 0,
          stagger: 0.3, // Retraso entre H2 y P
          duration: 1.2,
          ease: "power2.out",
        },
        0.3,
      );
    });
  </script>
</Layout>
