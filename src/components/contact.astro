<footer class="contact">
    <img src="./chicamocha.png" alt="" class="chica">
  <div class="contact-container">
    <div class="contact-header">
      <h2>Escribe tu propia historia</h2>
      <p>
        ¿Tienes dudas sobre nuestras maltas o quieres llevar a Guanerita a tu
        mesa? Déjanos un mensaje.
      </p>
    </div>

    <form class="contact-form">
      <div class="input-group">
        <label for="name">Nombre de pila</label>
        <input
          type="text"
          id="name"
          name="name"
          placeholder="Ej. Juan de la Tierra"
          required
        />
      </div>

      <div class="input-group">
        <label for="email">Correo electrónico</label>
        <input
          type="email"
          id="email"
          name="email"
          placeholder="tu@correo.com"
          required
        />
      </div>

      <div class="input-group">
        <label for="message">Tu mensaje</label>
        <textarea
          id="message"
          name="message"
          rows="4"
          placeholder="Háblanos de tu interés en nuestra alquimia..."
        ></textarea>
      </div>

      <button type="submit" class="btn-submit">Enviar Mensaje</button>
    </form>
  </div>
</footer>

<style>
  .contact {
    width: 100%;
    height: 100vh;
    background-color: var(--negro-quemado);
