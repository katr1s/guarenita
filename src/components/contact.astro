    position: relative;
    overflow: hidden;
  }

  .chica{
    width: 100%;
    position: absolute;
    z-index: 2;
    opacity: 0.1;
    mix-blend-mode: screen;
  }

  .contact-container {
    max-width: 600px;
    z-index: 3;
    width: 100%;
    border: 1px solid rgba(212, 175, 55, 0.3); /* Un dorado tenue */
    padding: 40px;
